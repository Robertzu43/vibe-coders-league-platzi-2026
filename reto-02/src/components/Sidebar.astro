---
import profile from '../data/profile.json';
---

<aside class="dashboard-sidebar">
  <div class="sidebar-profile">
    <div class="profile-avatar-ring">
      <img src={profile.avatar} alt={profile.displayName} class="profile-avatar" />
    </div>
    <span class="profile-name">{profile.displayName}</span>
    <span class="profile-subtitle">Music Listener</span>
  </div>

  <div class="sidebar-stats" id="sidebar-stats">
    <div class="stat-flip-card" data-stat-card="artists">
      <div class="stat-flip-inner">
        <div class="stat-flip-front stat-card">
          <span class="stat-value" data-stat="artists" style="color: var(--color-spotify);">--</span>
          <span class="stat-label">Artists</span>
        </div>
        <div class="stat-flip-back stat-card">
          <span class="stat-back-label">Top Artist</span>
          <span class="stat-back-value" style="color: var(--color-spotify);" id="stat-top-artist">Bad Bunny</span>
          <span class="stat-back-detail" id="stat-artist-minutes">2,847 min</span>
        </div>
      </div>
    </div>
    <div class="stat-flip-card" data-stat-card="tracks">
      <div class="stat-flip-inner">
        <div class="stat-flip-front stat-card">
          <span class="stat-value" data-stat="tracks" style="color: var(--color-accent-purple);">--</span>
          <span class="stat-label">Tracks</span>
        </div>
        <div class="stat-flip-back stat-card">
          <span class="stat-back-label">Top Track</span>
          <span class="stat-back-value" style="color: var(--color-accent-purple);" id="stat-top-track">Monaco</span>
          <span class="stat-back-detail" id="stat-track-plays">847 plays</span>
        </div>
      </div>
    </div>
    <div class="stat-flip-card" data-stat-card="genres">
      <div class="stat-flip-inner">
        <div class="stat-flip-front stat-card">
          <span class="stat-value" data-stat="genres" style="color: var(--color-accent-rose);">--</span>
          <span class="stat-label">Genres</span>
        </div>
        <div class="stat-flip-back stat-card">
          <span class="stat-back-label">Top Genre</span>
          <span class="stat-back-value" style="color: var(--color-accent-rose);" id="stat-top-genre">Pop</span>
          <span class="stat-back-detail" id="stat-genre-pct">26%</span>
        </div>
      </div>
    </div>
  </div>

  <div class="sidebar-footer">
    <span class="sidebar-powered">Powered by</span>
    <svg width="70" height="21" viewBox="0 0 70 21" fill="none" class="sidebar-spotify-logo">
      <path d="M10.5 0C4.7 0 0 4.7 0 10.5S4.7 21 10.5 21 21 16.3 21 10.5 16.3 0 10.5 0zm4.8 15.2c-.2.3-.6.4-.9.2-2.5-1.5-5.6-1.9-9.3-1-.4.1-.7-.1-.8-.5-.1-.4.1-.7.5-.8 4-.9 7.5-.5 10.3 1.2.3.2.4.6.2.9zm1.3-2.9c-.3.3-.7.5-1.1.3-2.9-1.8-7.2-2.3-10.6-1.3-.4.1-.9-.1-1-.5-.1-.4.1-.9.5-1 3.9-1.2 8.7-.6 12 1.4.4.2.5.7.2 1.1zm.1-3c-3.4-2-9.1-2.2-12.3-1.2-.5.1-1-.1-1.2-.6-.1-.5.1-1 .6-1.2 3.7-1.1 9.9-.9 13.8 1.4.5.3.6.8.4 1.3-.3.4-.8.5-1.3.3z" fill="var(--color-spotify)"/>
      <path d="M27.4 8.3c-1.8-.4-2.1-.7-2.1-1.3 0-.6.5-1 1.4-1 .8 0 1.6.3 2.4.9l.1.1.8-1.2-.1-.1c-.9-.8-2-1.1-3.2-1.1-1.8 0-3 1-3 2.5 0 1.6 1 2.2 3.1 2.7 1.7.4 2 .7 2 1.3 0 .7-.6 1.1-1.5 1.1-1 0-1.9-.4-2.8-1.1l-.1-.1-.9 1.2.1.1c1.1.9 2.4 1.4 3.7 1.4 1.9 0 3.2-1 3.2-2.6 0-1.4-.8-2.1-3.1-2.8z" fill="rgba(255,255,255,0.4)"/>
    </svg>
  </div>
</aside>

<style>
  .dashboard-sidebar {
    display: flex;
    flex-direction: column;
    padding: 28px 20px;
    border-right: 1px solid var(--color-border);
    overflow-y: auto;
    background: rgba(6, 5, 11, 0.5);
  }

  .sidebar-profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .profile-avatar-ring {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, var(--color-spotify), var(--color-accent-purple), var(--color-accent-rose), var(--color-spotify));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3px;
    animation: ringRotate 8s linear infinite;
    animation-play-state: paused;
    box-shadow: 0 0 24px rgba(29, 185, 84, 0.2);
    will-change: transform;
  }

  .profile-avatar-ring:hover {
    animation-play-state: running;
  }

  @keyframes ringRotate {
    to { transform: rotate(360deg); }
  }

  .profile-avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }

  .profile-name {
    font-family: var(--font-display);
    color: white;
    font-weight: 700;
    font-size: var(--text-base);
  }

  .profile-subtitle {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .sidebar-stats {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 24px;
    width: 100%;
  }

  /* ─── Flip Card Stats ──────────────────────────── */
  .stat-flip-card {
    perspective: 500px;
    height: 80px;
    cursor: pointer;
  }

  .stat-flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }

  .stat-flip-card:hover .stat-flip-inner {
    transform: rotateX(180deg);
  }

  .stat-flip-front,
  .stat-flip-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .stat-flip-back {
    transform: rotateX(180deg);
  }

  .stat-card {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0.01) 100%);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 14px 12px;
    text-align: center;
    width: 100%;
    height: 100%;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    display: block;
    line-height: 1;
  }

  .stat-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    display: block;
    margin-top: 4px;
  }

  .stat-back-label {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    display: block;
  }

  .stat-back-value {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    display: block;
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .stat-back-detail {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    display: block;
    margin-top: 2px;
    font-weight: 600;
  }

  .sidebar-footer {
    margin-top: auto;
    padding-top: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .sidebar-powered {
    font-size: 9px;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .sidebar-spotify-logo {
    opacity: 0.6;
    transition: opacity 0.3s;
  }

  .sidebar-spotify-logo:hover {
    opacity: 1;
  }

  @media (max-width: 1023px) {
    .profile-name,
    .profile-subtitle {
      display: none;
    }

    .profile-avatar-ring {
      width: 52px;
      height: 52px;
    }

    .sidebar-stats {
      flex-direction: row;
      gap: 4px;
    }

    .stat-flip-card {
      height: 60px;
      flex: 1;
    }

    .stat-value {
      font-size: var(--text-lg);
    }

    .stat-label {
      font-size: 7px;
    }

    .stat-back-value {
      font-size: var(--text-sm);
    }

    .stat-back-detail {
      font-size: 8px;
    }

    .sidebar-footer {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .dashboard-sidebar {
      flex-direction: row;
      align-items: center;
      padding: 8px 12px;
      gap: 8px;
      border-right: none;
      border-top: 1px solid var(--color-border);
      background: rgba(6, 5, 11, 0.85);
      backdrop-filter: blur(24px) saturate(1.3);
      -webkit-backdrop-filter: blur(24px) saturate(1.3);
    }

    .sidebar-profile {
      display: none;
    }

    .sidebar-footer {
      display: none;
    }

    .sidebar-stats {
      display: flex;
      flex-direction: row;
      gap: 8px;
      margin-top: 0;
      width: 100%;
      justify-content: center;
    }

    .stat-flip-card {
      flex: 1;
      max-width: 100px;
      height: 56px;
    }

    .stat-value {
      font-size: var(--text-base);
    }

    .stat-label {
      font-size: 8px;
    }

    .stat-back-value {
      font-size: 11px;
    }

    .stat-back-label {
      font-size: 7px;
    }

    .stat-back-detail {
      font-size: 7px;
    }
  }
</style>

<script>
  // Touch devices: tap to flip stat cards
  if (window.matchMedia('(hover: none)').matches) {
    document.querySelectorAll('.stat-flip-card').forEach(card => {
      card.addEventListener('click', () => {
        const inner = card.querySelector('.stat-flip-inner') as HTMLElement;
        if (!inner) return;
        const isFlipped = inner.style.transform === 'rotateX(180deg)';
        inner.style.transform = isFlipped ? '' : 'rotateX(180deg)';
      });
    });
  }
</script>
