---
import profile from '../data/profile.json';
---

<header class="dashboard-topbar">
  <div class="topbar-left">
    <svg width="24" height="24" viewBox="0 0 24 24"><circle cx="12" cy="12" r="12" fill="#1DB954"/><path d="M17.5 14.4c-.2 0-.3-.1-.5-.2-2.1-1.3-4.8-1.6-7.9-.9-.3.1-.5-.1-.6-.4-.1-.3.1-.5.4-.6 3.4-.8 6.3-.4 8.7 1 .3.2.4.4.2.7-.1.2-.2.4-.3.4zm1.3-2.7c-.2 0-.4-.1-.5-.2-2.4-1.5-6.1-1.9-8.9-1-.3.1-.7-.1-.8-.4-.1-.3.1-.7.4-.8 3.2-1 7.2-.5 9.9 1.2.3.2.4.5.2.8-.1.3-.3.4-.3.4zm.1-2.8c-2.9-1.7-7.6-1.9-10.3-1-.4.1-.7-.1-.8-.5-.1-.4.1-.7.5-.8 3.1-1 8.3-.8 11.5 1.2.3.2.4.6.2.9-.2.3-.5.4-.8.2h-.3z" fill="white"/></svg>
    <span class="topbar-brand">MY STATS</span>
  </div>
  <div class="topbar-tabs" role="tablist" aria-label="Time range">
    <button class="tab active" role="tab" aria-selected="true" data-range="short">4 Weeks</button>
    <button class="tab" role="tab" aria-selected="false" data-range="medium">6 Months</button>
    <button class="tab" role="tab" aria-selected="false" data-range="long">All Time</button>
  </div>
  <div class="topbar-avatar">
    <img src={profile.avatar} alt={profile.displayName} />
  </div>
</header>

<style>
  .dashboard-topbar {
    display: flex;
    align-items: center;
    padding: 0 24px;
    border-bottom: 1px solid var(--color-border);
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 10;
  }

  .topbar-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .topbar-brand {
    color: white;
    font-weight: 600;
    font-size: var(--text-base);
    letter-spacing: 0.05em;
  }

  .topbar-tabs {
    display: flex;
    gap: 4px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-sm);
    padding: 3px;
    margin-left: auto;
  }

  .tab {
    padding: 6px 14px;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: var(--color-text-secondary);
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: all var(--transition-fast);
  }

  .tab.active {
    background: var(--color-spotify);
    color: #000;
  }

  .tab:hover:not(.active) {
    background: rgba(255, 255, 255, 0.08);
  }

  .topbar-avatar {
    margin-left: 16px;
  }

  .topbar-avatar img {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    object-fit: cover;
  }

  @media (max-width: 767px) {
    .topbar-brand {
      display: none;
    }

    .topbar-tabs {
      margin-left: 8px;
    }
  }
</style>

<script>
  import '../scripts/time-range.ts';
</script>
