---
import profile from '../data/profile.json';
---

<header class="dashboard-topbar">
  <div class="topbar-left">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
      <rect x="2" y="10" width="3" height="8" rx="1.5" fill="#1DB954"/>
      <rect x="7" y="6" width="3" height="12" rx="1.5" fill="#1DB954"/>
      <rect x="12" y="3" width="3" height="18" rx="1.5" fill="#1DB954"/>
      <rect x="17" y="8" width="3" height="10" rx="1.5" fill="#1DB954"/>
    </svg>
    <span class="topbar-brand">MUSIC DNA</span>
  </div>
  <div class="topbar-tabs" role="tablist" aria-label="Time range">
    <button class="tab active" role="tab" aria-selected="true" data-range="short">4 Weeks</button>
    <button class="tab" role="tab" aria-selected="false" data-range="medium">6 Months</button>
    <button class="tab" role="tab" aria-selected="false" data-range="long">All Time</button>
  </div>
  <div class="topbar-avatar">
    <img src={profile.avatar} alt={profile.displayName} />
  </div>
</header>

<style>
  .dashboard-topbar {
    display: flex;
    align-items: center;
    padding: 0 24px;
    border-bottom: 1px solid var(--color-border);
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 10;
  }

  .topbar-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .topbar-brand {
    color: white;
    font-weight: 600;
    font-size: var(--text-base);
    letter-spacing: 0.05em;
  }

  .topbar-tabs {
    display: flex;
    gap: 4px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-sm);
    padding: 3px;
    margin-left: auto;
  }

  .tab {
    padding: 6px 14px;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: var(--color-text-secondary);
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: all var(--transition-fast);
  }

  .tab.active {
    background: var(--color-spotify);
    color: #000;
  }

  .tab:hover:not(.active) {
    background: rgba(255, 255, 255, 0.08);
  }

  .topbar-avatar {
    margin-left: 16px;
  }

  .topbar-avatar img {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    object-fit: cover;
  }

  @media (max-width: 767px) {
    .topbar-brand {
      display: none;
    }

    .topbar-tabs {
      margin-left: 8px;
    }
  }
</style>

<script>
  import '../scripts/time-range.ts';
</script>
