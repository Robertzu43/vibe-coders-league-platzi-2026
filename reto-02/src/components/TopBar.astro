---
import profile from '../data/profile.json';
---

<header class="dashboard-topbar">
  <div class="topbar-left">
    <div class="topbar-logo">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <rect x="2" y="10" width="3" height="8" rx="1.5" fill="url(#logoGrad)"/>
        <rect x="7" y="6" width="3" height="12" rx="1.5" fill="url(#logoGrad)"/>
        <rect x="12" y="3" width="3" height="18" rx="1.5" fill="url(#logoGrad)"/>
        <rect x="17" y="8" width="3" height="10" rx="1.5" fill="url(#logoGrad)"/>
        <defs>
          <linearGradient id="logoGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#1DB954"/>
            <stop offset="100%" stop-color="#1ed760"/>
          </linearGradient>
        </defs>
      </svg>
    </div>
    <span class="topbar-brand">MUSIC DNA</span>
  </div>
  <div class="topbar-tabs" role="tablist" aria-label="Time range">
    <div class="tab-indicator"></div>
    <button class="tab active" role="tab" aria-selected="true" data-range="short">4 Weeks</button>
    <button class="tab" role="tab" aria-selected="false" data-range="medium">6 Months</button>
    <button class="tab" role="tab" aria-selected="false" data-range="long">All Time</button>
  </div>
  <div class="topbar-avatar">
    <img src={profile.avatar} alt={profile.displayName} />
  </div>
</header>

<style>
  .dashboard-topbar {
    display: flex;
    align-items: center;
    padding: 0 28px;
    border-bottom: 1px solid var(--color-border);
    background: rgba(6, 5, 11, 0.7);
    backdrop-filter: blur(24px) saturate(1.3);
    -webkit-backdrop-filter: blur(24px) saturate(1.3);
    z-index: 10;
  }

  .topbar-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .topbar-logo {
    display: flex;
    filter: drop-shadow(0 0 8px rgba(29, 185, 84, 0.4));
  }

  .topbar-brand {
    font-family: var(--font-display);
    color: white;
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.15em;
  }

  .topbar-tabs {
    display: flex;
    gap: 2px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-full);
    padding: 3px;
    margin-left: auto;
    position: relative;
  }

  .tab-indicator {
    display: none;
  }

  .tab {
    padding: 7px 18px;
    border-radius: var(--radius-full);
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    font-family: var(--font-body);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    letter-spacing: 0.02em;
    position: relative;
    z-index: 1;
  }

  .tab.active {
    background: var(--color-spotify);
    color: #000;
    box-shadow: 0 0 16px rgba(29, 185, 84, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.2);
    font-weight: 700;
  }

  .tab:hover:not(.active) {
    color: var(--color-text-secondary);
    background: rgba(255, 255, 255, 0.05);
  }

  .topbar-avatar {
    margin-left: 20px;
  }

  .topbar-avatar img {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 2px solid rgba(29, 185, 84, 0.3);
    object-fit: cover;
    transition: border-color 0.3s;
  }

  .topbar-avatar img:hover {
    border-color: var(--color-spotify);
  }

  @media (max-width: 767px) {
    .dashboard-topbar {
      padding: 0 12px;
    }

    .topbar-brand {
      display: none;
    }

    .topbar-logo {
      display: none;
    }

    .topbar-tabs {
      margin-left: 4px;
      flex: 1;
      justify-content: center;
    }

    .tab {
      padding: 6px 14px;
      font-size: 10px;
    }

    .topbar-avatar img {
      width: 28px;
      height: 28px;
    }
  }
</style>

<script>
  import '../scripts/time-range.ts';
</script>
