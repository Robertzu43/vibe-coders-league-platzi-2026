---
import SectionInfo from './SectionInfo.astro';
import artists from '../data/top-artists-short.json';

const genreCounts: Record<string, number> = {};
artists.forEach(a => {
  a.genres.forEach(g => {
    genreCounts[g] = (genreCounts[g] || 0) + 1;
  });
});
const top6 = Object.entries(genreCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6);
const top6Total = top6.reduce((sum, [, c]) => sum + c, 0);
const rawPercents = top6.map(([name, count]) => ({ name, raw: (count / top6Total) * 100 }));
// Round so they sum to exactly 100 (largest remainder method)
let floored = rawPercents.map(g => ({ ...g, percent: Math.floor(g.raw) }));
let remainder = 100 - floored.reduce((s, g) => s + g.percent, 0);
const byRemainder = [...floored].sort((a, b) => (b.raw - b.percent) - (a.raw - a.percent));
for (let i = 0; i < remainder; i++) byRemainder[i].percent++;
const topGenres = floored;

const gradientColors = [
  '#1DB954,#1ed760',
  '#a855f7,#7c3aed',
  '#f43f5e,#e11d48',
  '#3b82f6,#2563eb',
  '#f59e0b,#d97706',
  '#06b6d4,#0891b2'
];
---

<section class="genre-breakdown glass-card" data-section="genres">
  <h2 class="section-heading">Genre Breakdown</h2>
    <SectionInfo
      sectionId="genres"
      descriptions={{
        short: "Your top genres from the last 4 weeks of listening.",
        medium: "Your top genres from the last 6 months of listening.",
        long: "Your top genres across your entire listening history.",
      }}
    />
  <div class="genre-grid" id="genre-bars">
    {topGenres.map((genre, i) => (
      <div class="genre-tile" style={`--genre-color: ${gradientColors[i].split(',')[0]}; --genre-color-end: ${gradientColors[i].split(',')[1]}`}>
        <div class="genre-big-number">
          <span class="genre-number" data-target-value={genre.percent.toString()} style={`color: ${gradientColors[i].split(',')[0]}`}>0</span>
          <span class="genre-unit" style={`color: ${gradientColors[i].split(',')[0]}`}>%</span>
        </div>
        <div class="genre-bar-wrap">
          <div
            class="genre-fill"
            data-target-width={`${genre.percent}%`}
            style={`background: linear-gradient(90deg, ${gradientColors[i]});`}
          ></div>
        </div>
        <span class="genre-name">{genre.name}</span>
      </div>
    ))}
  </div>
</section>

<style is:global>
  .genre-breakdown {
    padding: 24px;
    overflow: visible;
  }

  .genre-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .genre-tile {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0.01) 100%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    padding: 24px 12px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .genre-tile::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    border-radius: 0 0 16px 16px;
    background: linear-gradient(90deg, var(--genre-color), var(--genre-color-end));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .genre-tile:hover {
    background: rgba(255, 255, 255, 0.06);
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .genre-tile:hover::after {
    opacity: 1;
  }

  .genre-big-number {
    display: flex;
    align-items: baseline;
    justify-content: center;
    margin-bottom: 10px;
  }

  .genre-number {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 800;
    line-height: 0.85;
    font-variant-numeric: tabular-nums;
    letter-spacing: -3px;
    text-shadow: 0 0 40px currentColor, 0 0 80px currentColor;
  }

  .genre-unit {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    margin-left: 2px;
    opacity: 0.6;
  }

  .genre-bar-wrap {
    width: 100%;
    height: 5px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 10px;
  }

  .genre-fill {
    height: 100%;
    border-radius: 3px;
    width: 0;
    box-shadow: 0 0 8px currentColor;
  }

  .genre-name {
    color: var(--color-text-secondary);
    font-size: 10px;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  @media (max-width: 767px) {
    .genre-breakdown {
      padding: 16px;
    }

    .genre-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .genre-tile {
      padding: 16px 8px 12px;
      border-radius: 12px;
    }

    .genre-number {
      font-size: 52px;
      letter-spacing: -3px;
    }

    .genre-unit {
      font-size: 20px;
    }

    .genre-name {
      font-size: 9px;
    }
  }
</style>
