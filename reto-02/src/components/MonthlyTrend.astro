---
const monthlyData = [
  { month: 'Apr', hours: 45 },
  { month: 'May', hours: 52 },
  { month: 'Jun', hours: 48 },
  { month: 'Jul', hours: 65 },
  { month: 'Aug', hours: 72 },
  { month: 'Sep', hours: 58 },
  { month: 'Oct', hours: 80 },
  { month: 'Nov', hours: 95 },
  { month: 'Dec', hours: 110 },
  { month: 'Jan', hours: 88 },
  { month: 'Feb', hours: 76 },
  { month: 'Mar', hours: 92 },
];
const maxHours = Math.max(...monthlyData.map(d => d.hours));
---

<section class="monthly-trend glass-card" data-section="trend">
  <h2 class="section-heading">Monthly Trend</h2>
  <p class="section-subtitle">Hours listened per month</p>
  <div class="trend-chart">
    <svg viewBox="0 0 440 150" class="trend-svg" preserveAspectRatio="none">
      <defs>
        <linearGradient id="trendGradient" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="rgba(29,185,84,0.3)" />
          <stop offset="100%" stop-color="rgba(29,185,84,0)" />
        </linearGradient>
      </defs>
      <polygon
        points={`${monthlyData.map((d, i) => `${(i / (monthlyData.length - 1)) * 440},${150 - (d.hours / maxHours) * 130}`).join(' ')} 440,150 0,150`}
        fill="url(#trendGradient)"
      />
      <polyline
        points={monthlyData.map((d, i) => `${(i / (monthlyData.length - 1)) * 440},${150 - (d.hours / maxHours) * 130}`).join(' ')}
        fill="none"
        stroke="#1DB954"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      {monthlyData.map((d, i) => (
        <circle
          cx={(i / (monthlyData.length - 1)) * 440}
          cy={150 - (d.hours / maxHours) * 130}
          r="4"
          fill="#1DB954"
          stroke="#0a0014"
          stroke-width="2"
        />
      ))}
    </svg>
    <div class="trend-labels">
      {monthlyData.map(d => (
        <span class="trend-label">{d.month}</span>
      ))}
    </div>
  </div>
  <div class="trend-stats">
    <div class="trend-stat">
      <span class="trend-stat-value" style="color: var(--color-spotify);">892</span>
      <span class="trend-stat-label">Total Hours</span>
    </div>
    <div class="trend-stat">
      <span class="trend-stat-value" style="color: var(--color-accent-purple);">74</span>
      <span class="trend-stat-label">Avg/Month</span>
    </div>
    <div class="trend-stat">
      <span class="trend-stat-value" style="color: var(--color-accent-rose);">Dec</span>
      <span class="trend-stat-label">Peak Month</span>
    </div>
  </div>
</section>

<style>
  .monthly-trend {
    padding: 20px;
  }

  .section-heading {
    color: white;
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: 4px;
  }

  .section-subtitle {
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    margin-top: -12px;
    margin-bottom: 16px;
  }

  .trend-chart {
    position: relative;
  }

  .trend-svg {
    width: 100%;
    height: 150px;
    display: block;
  }

  .trend-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 8px;
  }

  .trend-label {
    color: var(--color-text-muted);
    font-size: 9px;
  }

  .trend-stats {
    display: flex;
    gap: 20px;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border);
  }

  .trend-stat {
    text-align: center;
    flex: 1;
  }

  .trend-stat-value {
    display: block;
    font-size: var(--text-xl);
    font-weight: 700;
  }

  .trend-stat-label {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 2px;
  }
</style>
