# Este archivo es solo documentación — Make gestiona las credenciales internamente.
# No se importa ni se usa directamente en Make.

# OpenWeatherMap — https://openweathermap.org/api (plan Free)
OWM_API_KEY=your_openweathermap_api_key

# Twilio — https://www.twilio.com/
# SMS (no WhatsApp) — trial gratis con ~$15 de crédito
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Make Webhook — URL del escenario receptor de alertas TransMilenio
MAKE_WEBHOOK_URL=https://hook.us2.make.com/your_webhook_id

# Google Sheets — el sheet vinculado al Google Form
SPREADSHEET_ID=your_spreadsheet_id

# MacroDroid — configurado en el celular Android
# Trigger: Notification Received → WhatsApp → contiene "TransMilenio"
# Action: HTTP POST al MAKE_WEBHOOK_URL con body {"text": "{notification_text}"}
