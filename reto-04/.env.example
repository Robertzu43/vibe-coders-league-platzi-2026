# Este archivo es solo documentación — Make gestiona las credenciales internamente.
# No se importa ni se usa directamente en Make.

# OpenWeatherMap — https://openweathermap.org/api (plan Free)
OWM_API_KEY=your_openweathermap_api_key

# X / Twitter — https://developer.x.com/ (plan Basic $200/mes)
X_BEARER_TOKEN=your_x_bearer_token

# Twilio — https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_MESSAGING_SERVICE_SID=your_messaging_service_sid
TWILIO_TO=+57XXXXXXXXXX

# Google Sheets — https://sheets.google.com
SPREADSHEET_ID=your_spreadsheet_id
