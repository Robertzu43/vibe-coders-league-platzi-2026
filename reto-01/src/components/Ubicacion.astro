---
import { Image } from 'astro:assets';
import venueImg from '../assets/images/venue.jpg';
---

<section id="ubicacion">
  <div class="venue-hero">
    <Image
      src={venueImg}
      alt="Centro de Convenciones Ágora, Bogotá"
      class="venue-image"
      loading="lazy"
      widths={[600, 900, 1200]}
      sizes="100vw"
    />
    <div class="venue-overlay"></div>
    <div class="venue-text">
      <h2 class="venue-name">Centro de Convenciones Ágora</h2>
      <p class="venue-city">Bogotá, Colombia</p>
    </div>
  </div>

  <div class="venue-cards container">
    <div class="venue-card" style="opacity: 0; transform: translateY(40px);">
      <div class="card-icon">📍</div>
      <span class="card-label">Dirección</span>
      <p class="card-content">
        Carrera 37 No. 24-67<br />
        Bogotá, Colombia
      </p>
    </div>
    <div class="venue-card" style="opacity: 0; transform: translateY(40px);">
      <div class="card-icon">📅</div>
      <span class="card-label">Fecha</span>
      <p class="card-content">
        15–17 Octubre 2026<br />
        3 días de inmersión total
      </p>
    </div>
    <div class="venue-card" style="opacity: 0; transform: translateY(40px);">
      <div class="card-icon">🚇</div>
      <span class="card-label">Cómo Llegar</span>
      <p class="card-content">
        Metro línea 1, estación Ágora<br />
        Transmilenio ruta 93
      </p>
    </div>
    <div class="venue-card" style="opacity: 0; transform: translateY(40px);">
      <div class="card-icon">🅿️</div>
      <span class="card-label">Parqueadero</span>
      <p class="card-content">
        Disponible en sitio<br />
        Acceso 24 horas
      </p>
    </div>
  </div>
</section>

<style>
  #ubicacion {
    position: relative;
    z-index: 1;
  }

  .venue-hero {
    position: relative;
    height: 70vh;
    overflow: hidden;
    clip-path: inset(0 100% 0 0);
  }

  .venue-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.15);
    transition: transform 0.6s ease-out;
  }

  .venue-hero.revealed .venue-image {
    transform: scale(1);
  }

  .venue-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(124, 58, 237, 0.5) 0%, rgba(0, 0, 0, 0.6) 50%, rgba(59, 130, 246, 0.4) 100%);
    mix-blend-mode: multiply;
    opacity: 0;
    transition: opacity 0.8s ease-out 0.4s;
  }

  .venue-hero.revealed .venue-overlay {
    opacity: 1;
  }

  .venue-text {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 var(--container-padding);
    z-index: 1;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out 0.6s, transform 0.8s ease-out 0.6s;
  }

  .venue-hero.revealed .venue-text {
    opacity: 1;
    transform: translateY(0);
  }

  .venue-name {
    font-size: var(--text-section-title);
    color: white;
    font-weight: bold;
    margin: 0;
    line-height: 1.1;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }

  .venue-city {
    font-size: var(--text-h3);
    color: rgba(255, 255, 255, 0.8);
    margin-top: 12px;
    margin-bottom: 0;
  }

  /* Info cards grid */
  .venue-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: -60px;
    position: relative;
    z-index: 2;
    padding-bottom: var(--section-padding);
  }

  .venue-card {
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 28px 24px;
    text-align: center;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .venue-card:hover {
    transform: translateY(-4px);
    border-color: rgba(124, 58, 237, 0.3);
  }

  .card-icon {
    font-size: 2rem;
    margin-bottom: 16px;
  }

  .card-label {
    display: block;
    font-size: var(--text-small);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    font-weight: var(--font-weight-semibold);
    margin-bottom: 10px;
  }

  .card-content {
    font-size: var(--text-body);
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .venue-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .venue-hero {
      height: 50vh;
    }

    .venue-name {
      font-size: clamp(28px, 7vw, 48px);
    }

    .venue-cards {
      grid-template-columns: 1fr;
      margin-top: -40px;
      gap: 16px;
    }

    .venue-card {
      padding: 24px 20px;
    }
  }
</style>
