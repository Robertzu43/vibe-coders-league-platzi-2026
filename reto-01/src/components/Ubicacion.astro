---
// Ubicacion.astro — Venue section with split layout
import { Image } from 'astro:assets';
import venueImg from '../assets/images/venue.jpg';
---

<section id="ubicacion">
  <div class="ubicacion-split">
    <div class="venue-image-side">
      <Image
        src={venueImg}
        alt="Centro de Convenciones Ágora, Bogotá"
        class="venue-image"
        loading="lazy"
        widths={[600, 900, 1200]}
        sizes="(max-width: 767px) 100vw, 60vw"
      />
      <div class="venue-overlay"></div>
      <div class="venue-text">
        <h2 class="venue-name">Centro de Convenciones Ágora</h2>
        <p class="venue-city">Bogotá, Colombia</p>
      </div>
    </div>

    <div class="venue-info-panel">
      <div class="info-block" style="opacity: 0; transform: translateY(20px);">
        <span class="info-label">Dirección</span>
        <p class="info-content">
          Carrera 37 No. 24-67<br />
          Bogotá, Colombia
        </p>
      </div>
      <div class="info-block" style="opacity: 0; transform: translateY(20px);">
        <span class="info-label">Cómo Llegar</span>
        <p class="info-content">
          Metro línea 1, estación Ágora.<br />
          Bus Transmilenio ruta 93.<br />
          Parqueadero disponible en sitio.
        </p>
      </div>
      <div class="info-block" style="opacity: 0; transform: translateY(20px);">
        <span class="info-label">Fecha</span>
        <p class="info-content">15–17 Octubre 2026</p>
      </div>
    </div>
  </div>
</section>

<style>
  .ubicacion-split {
    display: flex;
    min-height: 80vh;
  }

  .venue-image-side {
    flex: 0 0 60%;
    position: relative;
    overflow: hidden;
  }

  .venue-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .venue-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(124, 58, 237, 0.4) 0%, rgba(10, 10, 10, 0.6) 50%, rgba(59, 130, 246, 0.3) 100%);
    mix-blend-mode: multiply;
  }

  .venue-text {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 var(--container-padding);
    z-index: 1;
  }

  .venue-name {
    font-size: var(--text-section-title);
    color: white;
    font-weight: bold;
    margin: 0;
    line-height: 1.1;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }

  .venue-city {
    font-size: var(--text-h3);
    color: rgba(255, 255, 255, 0.8);
    margin-top: 12px;
    margin-bottom: 0;
  }

  .venue-info-panel {
    flex: 0 0 40%;
    background: var(--color-bg-dark);
    padding: 60px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
  }

  .info-block {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 32px 0;
  }

  .info-block + .info-block {
    border-top: 1px solid var(--color-border);
  }

  .info-label {
    font-size: var(--text-small);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent, #7c3aed);
    font-weight: var(--font-weight-semibold, 600);
  }

  .info-content {
    font-size: var(--text-body);
    color: white;
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 767px) {
    .ubicacion-split {
      flex-direction: column;
    }

    .venue-image-side {
      flex: none;
      height: 50vh;
    }

    .venue-info-panel {
      flex: none;
      padding: 40px var(--container-padding);
    }

    .venue-name {
      font-size: clamp(28px, 7vw, 48px);
    }
  }
</style>
