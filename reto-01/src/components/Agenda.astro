---
import agenda from '../data/agenda.json';

const tagStyles: Record<string, { bg: string; color: string }> = {
  'Web3':        { bg: 'rgba(139, 92, 246, 0.15)',  color: 'var(--color-tag-web3)' },
  'Vibe Coding': { bg: 'rgba(6, 182, 212, 0.15)',   color: 'var(--color-tag-vibecoding)' },
  'Crypto':      { bg: 'rgba(245, 158, 11, 0.15)',  color: 'var(--color-tag-crypto)' },
  'AI':          { bg: 'rgba(16, 185, 129, 0.15)',  color: 'var(--color-tag-ai)' },
};
---

<section id="agenda" class="section" style="position: relative; z-index: 1;">
  <div class="container">
    <h2
      class="section-title gsap-reveal"
      style="color: white; opacity: 0; transform: translateY(60px);"
    >
      Agenda
    </h2>

    {agenda.days.map((day) => (
      <div class="day-block">
        <div class="day-header">
          <span class="day-label">{day.label}</span>
          <span class="day-title">{day.title}</span>
        </div>

        <div class="timeline">
          {day.events.map((event, i) => {
            const isRight = i % 2 === 0;
            const tag = tagStyles[event.tag] ?? { bg: 'rgba(255,255,255,0.1)', color: 'white' };
            return (
              <div
                class={`timeline-item ${isRight ? 'timeline-item--right' : 'timeline-item--left'}`}
                style={`opacity: 0; transform: translateX(${isRight ? '40px' : '-40px'});`}
              >
                <div class="timeline-dot"></div>
                <div class="event-card">
                  <span class="event-time">{event.time}</span>
                  <h3 class="event-title">{event.title}</h3>
                  <p class="event-speaker">{event.speaker}</p>
                  <span
                    class="event-tag"
                    style={`background: ${tag.bg}; color: ${tag.color};`}
                  >
                    {event.tag}
                  </span>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .section {
    padding: var(--section-padding) 0;
  }

  .container {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .day-block {
    margin-bottom: 80px;
  }

  .day-block:last-child {
    margin-bottom: 0;
  }

  .day-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 48px;
  }

  .day-label {
    font-weight: var(--font-weight-bold);
    color: white;
    font-size: var(--text-h3);
  }

  .day-title {
    color: var(--color-text-secondary);
    font-size: var(--text-body);
  }

  /* Desktop timeline */
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-border);
    transform: translateX(-50%);
  }

  .timeline-item {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .timeline-item--right {
    flex-direction: row;
    justify-content: flex-end;
  }

  .timeline-item--left {
    flex-direction: row;
    justify-content: flex-start;
  }

  .timeline-item--right .event-card {
    margin-right: calc(50% + 32px);
    width: calc(50% - 32px);
  }

  .timeline-item--left .event-card {
    margin-left: calc(50% + 32px);
    width: calc(50% - 32px);
  }

  .timeline-dot {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-accent);
    transform: translate(-50%, -50%);
    z-index: 1;
  }

  .event-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 24px;
  }

  .event-time {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    font-weight: var(--font-weight-medium);
    display: block;
  }

  .event-title {
    font-size: var(--text-h3);
    color: white;
    margin-top: 8px;
    margin-bottom: 0;
  }

  .event-speaker {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    margin-top: 4px;
    margin-bottom: 12px;
  }

  .event-tag {
    display: inline-block;
    font-size: 12px;
    padding: 4px 12px;
    border-radius: 100px;
    font-weight: var(--font-weight-medium);
  }

  /* Tablet / Mobile: linear layout, line on left */
  @media (max-width: 1199px) {
    .timeline::before {
      left: 8px;
      transform: none;
    }

    .timeline-item,
    .timeline-item--right,
    .timeline-item--left {
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
    }

    .timeline-item--right .event-card,
    .timeline-item--left .event-card {
      margin-left: 40px;
      margin-right: 0;
      width: calc(100% - 40px);
    }

    .timeline-dot {
      left: 8px;
      top: 24px;
      transform: translate(-50%, 0);
    }

    /* Reset inline translateX on mobile */
    .timeline-item[style] {
      transform: none !important;
    }
  }
</style>
